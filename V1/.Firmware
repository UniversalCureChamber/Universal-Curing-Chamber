#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <Adafruit_SHT31.h>
#include <ArduinoOTA.h>
#include <PID_v1.h>
#include <Preferences.h>
#include "time.h"

// --- AS-BUILT PIN MAPPING [Source: master code.txt, SCH_Schematic1] ---
#define I2C_SDA 21
#define I2C_SCL 22
#define FAN_T_IN 25
#define FAN_T_OUT 14
#define FAN_B_IN 27
#define FAN_B_OUT 26
#define PELTIER_T 32
#define PELTIER_B 33
#define THERM_T_HOT 39 
#define THERM_T_COLD 36 
#define THERM_B_HOT 35 
#define THERM_B_COLD 34

// --- DATA LOGGING & PERSISTENCE ---
const int MAX_POINTS = 96; 
// FIX 1: Allocated 6 bytes [HH:MM + null] to prevent memory corruption
struct DataPoint { float t; float h; float d; char time[6]; }; 
DataPoint history[MAX_POINTS];
int writeIdx = 0;
unsigned long lastSample = 0;
unsigned long currentInterval = 15000; 
bool is24HourMode = false;
String bootTimestamp = "Syncing...";

// --- SYSTEM OBJECTS ---
Preferences prefs;
const char* ssid = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"; 
const char* password = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"; 
const char* ntpServer = "pool.ntp.org";
Adafruit_SHT31 sht31 = Adafruit_SHT31();
WebServer server(80);

double targetT, targetH, targetDew, curT, curH, curDew, pwrT, pwrB;
double pidHumInput, pidHumTarget; 
int fT_in=0, fT_out=0, fB_in=0, fB_out=0;
bool isAssistMode = false, isKilled = false, useDewPointMode, useCelsius = false;

PID pidTemp(&curT, &pwrT, &targetT, 2, 5, 1, REVERSE); 
PID pidHum(&pidHumInput, &pwrB, &pidHumTarget, 2, 5, 1, REVERSE);

float toDisp(float f) { return useCelsius ? (f - 32) * 5.0 / 9.0 : f; }
float fromDisp(float c) { return useCelsius ? (c * 9.0 / 5.0) + 32 : c; }
String u() { return useCelsius ? "C" : "F"; }

String getUptime() {
  unsigned long sec = millis() / 1000;
  return String(sec / 86400) + "d " + String((sec % 86400) / 3600) + "h " + String((sec % 3600) / 60) + "m";
}

String getResetReason() {
  esp_reset_reason_t reason = esp_reset_reason();
  switch (reason) {
    case ESP_RST_POWERON: return "Power Outage / Manual Toggle";
    case ESP_RST_SW:      return "Software Restart (OTA/Update)";
    case ESP_RST_PANIC:   return "System Crash (Exception)";
    case ESP_RST_WDT:     return "Hardware Watchdog (Hang)";
    default:              return "Normal Reset";
  }
}

float getF(int pin) {
  int raw = analogRead(pin);
  if (raw < 10) return 0.0;
  float resis = 10000.0 * ((4095.0 / (float)raw) - 1.0);
  float tempK = 1.0 / (1.0/298.15 + (1.0/3950.0) * log(resis/10000.0));
  return ((tempK - 273.15) * 1.8) + 32.0;
}

String getColor(float temp) {
  if (temp > 150) return "red";
  if (temp > 120) return "orange";
  return "green";
}

void handleData() {
  String json = "[";
  for (int i = 0; i < MAX_POINTS; i++) {
    int idx = (writeIdx + i) % MAX_POINTS;
    if (history[idx].t == 0) continue;
    json += "{\"t\":" + String(history[idx].t, 1) + ",\"h\":" + String(history[idx].h, 1) + ",\"d\":" + String(history[idx].d, 1) + ",\"time\":\"" + String(history[idx].time) + "\"}";
    if (i < MAX_POINTS - 1) json += ",";
  }
  json += "]";
  server.send(200, "application/json", json);
}

void handleRoot() {
  String html = "<html><head><meta http-equiv='refresh' content='30'><script src='https://cdn.jsdelivr.net/npm/chart.js'></script><style>";
  html += "body{text-align:center;font-family:sans-serif;background:#eee; padding:20px;} .container{display:flex; justify-content:center; gap:20px;}";
  html += ".sidebar{display:flex; flex-direction:column; gap:10px; width:240px; text-align:left;} .main-content{flex-grow:1; max-width:900px;}";
  html += ".btn-kill{background:red;color:white;padding:15px;font-weight:bold;border-radius:5px;border:none;cursor:pointer;}";
  html += ".btn-mode, .btn-unit{padding:12px; font-weight:bold; border-radius:5px; border:2px solid #333; cursor:pointer;}";
  html += ".active{background:#4CAF50; color:white;} .inactive{background:#fff; color:#333;} .monitor-box{background:#ddd; padding:15px; margin:10px; border-radius:10px;}";
  html += ".monitor-flex{display:flex; align-items:center; justify-content:center;} .unit-toggle{display:flex; flex-direction:column; gap:5px; margin-right:20px; border-right:1px solid #999; padding-right:20px;}";
  html += ".sensor-row{display:flex; justify-content:center; gap:8px; margin:10px;} .sensor{padding:10px; border-radius:5px; color:white; width:115px; font-size:10px; font-weight:bold;} .green{background:green;} .orange{background:orange;} .red{background:red;}";
  html += ".chart-container{background:white; padding:15px; border:3px solid black;}";
  html += "</style></head><body><h1>" + String(toDisp(curT),1) + u() + " | " + String(curH,1) + "% RH | Dew Point: " + String(toDisp(curDew),1) + u() + "</h1>";

  html += "<div class='monitor-box' style='background:#fff3cd; border:1px solid #ffeeba;'>";
  html += "<b>System Diagnostic:</b> Last Reset: " + getResetReason() + " | <b>Boot Time:</b> " + bootTimestamp + " | <b>Uptime:</b> " + getUptime() + "</div>";

  html += "<div class='container'><div class='sidebar'><h3>Control Mode</h3>";
  html += "<a href='/mode?m=0'><button class='btn-mode " + String(!useDewPointMode?"active":"inactive") + "'>Temp & Humidity</button></a>";
  html += "<a href='/mode?m=1'><button class='btn-mode " + String(useDewPointMode?"active":"inactive") + "'>Dew Point Control</button></a><br>";
  html += "<a href='/kill'><button class='btn-kill'>EMERGENCY SHUTOFF</button></a></div>";

  html += "<div class='main-content'><div class='monitor-box'><div class='monitor-flex'>";
  html += "<div class='unit-toggle'><label>Unit</label><a href='/unit?u=0'><button class='btn-unit " + String(!useCelsius?"active":"inactive") + "'>F</button></a>";
  html += "<a href='/unit?u=1'><button class='btn-unit " + String(useCelsius?"active":"inactive") + "'>C</button></a></div>";

  html += "<form action='/set'><div><label>Target Temp (" + u() + "): </label><input type='number' name='t' step='0.1' style='font-size:24px;width:120px' value='" + String(toDisp(targetT),1) + "'></div>";
  html += "<div><label>Target Humidity: </label><input type='number' name='h' step='0.1' style='font-size:24px;width:120px' value='" + String(targetH,1) + "' " + String(useDewPointMode?"disabled":"") + "></div>";
  html += "<div><label>Target Dew Point (" + u() + "): </label><input type='number' name='d' step='0.1' style='font-size:24px;width:120px' value='" + String(toDisp(targetDew),1) + "' " + String(!useDewPointMode?"disabled":"") + "></div>";
  html += "<input type='submit' value='Update Active Targets' style='font-size:18px; padding:10px;'></form></div></div>";

  html += "<div class='monitor-box'><b>Power:</b> T=" + String((pwrT/255)*100,0) + "% | B=" + String(isAssistMode?100:(pwrB/255)*100,0) + "%<br>";
  html += "<b>Fans:</b> T-In: " + String((fT_in/255.0)*100,0) + "% | T-Out: " + String((fT_out/255.0)*100,0) + "% | B-In: " + String((fB_in/255.0)*100,0) + "% | B-Out: " + String((fB_out/255.0)*100,0) + "%</div>";

  html += "<h3>Safety Sensor Array</h3><div class='sensor-row'>";
  float t1=getF(THERM_T_HOT), t2=getF(THERM_T_COLD), t3=getF(THERM_B_HOT), t4=getF(THERM_B_COLD);
  html += "<div class='sensor " + getColor(t1) + "'>TOP OUT: " + String(toDisp(t1),0) + u() + "</div><div class='sensor " + getColor(t2) + "'>TOP IN: " + String(toDisp(t2),0) + u() + "</div>";
  html += "<div class='sensor " + getColor(t3) + "'>BTM OUT: " + String(toDisp(t3),0) + u() + "</div><div class='sensor " + getColor(t4) + "'>BTM IN: " + String(toDisp(t4),0) + u() + "</div></div>";

  html += "<div class='chart-container'><canvas id='curingChart'></canvas></div></div></div>";
  html += "<script>fetch('/data').then(r=>r.json()).then(data=>{const ctx=document.getElementById('curingChart').getContext('2d');";
  html += "new Chart(ctx,{type:'line',data:{labels:data.map(d=>d.time),";
  html += "datasets:[{label:'Temp (" + u() + ")',data:data.map(d=>" + String(useCelsius?"(d.t-32)*5/9":"d.t") + "),borderColor:'red',tension:0.3},";
  html += "{label:'Humidity',data:data.map(d=>d.h),borderColor:'blue',tension:0.3},";
  html += "{label:'Dew (" + u() + ")',data:data.map(d=>" + String(useCelsius?"(d.d-32)*5/9":"d.d") + "),borderColor:'green',tension:0.3}]},";
  html += "options:{aspectRatio:4, scales:{y:{beginAtZero:false}}}});});</script></body></html>";
  server.send(200, "text/html", html); 
}

void handleSet() { 
  if (server.hasArg("t")) targetT = fromDisp(server.arg("t").toDouble()); 
  if (server.hasArg("h")) targetH = server.arg("h").toDouble(); 
  if (server.hasArg("d")) targetDew = fromDisp(server.arg("d").toDouble()); 
  prefs.begin("curing", false);
  prefs.putDouble("t", targetT); prefs.putDouble("h", targetH); prefs.putDouble("d", targetDew);
  prefs.end();
  server.sendHeader("Location","/"); server.send(303); 
}

void handleUnit() { useCelsius = server.arg("u").toInt(); prefs.begin("curing", false); prefs.putBool("useCelsius", useCelsius); prefs.end(); server.sendHeader("Location","/"); server.send(303); }
void handleMode() { useDewPointMode = server.arg("m").toInt(); prefs.begin("curing", false); prefs.putBool("mode", useDewPointMode); prefs.end(); server.sendHeader("Location","/"); server.send(303); }
void handleKill() { isKilled=true; pwrT=0; pwrB=0; ledcWrite(PELTIER_T,0); ledcWrite(PELTIER_B,0); server.sendHeader("Location","/"); server.send(303); }

void setup() {
  Wire.begin(I2C_SDA, I2C_SCL); sht31.begin(0x44); 
  ledcAttach(PELTIER_T, 5000, 8); ledcAttach(PELTIER_B, 5000, 8);
  ledcAttach(FAN_T_IN, 5000, 8); ledcAttach(FAN_T_OUT, 5000, 8);
  ledcAttach(FAN_B_IN, 5000, 8); ledcAttach(FAN_B_OUT, 5000, 8);
  
  prefs.begin("curing", true);
  targetT = prefs.getDouble("t", 60.0); targetH = prefs.getDouble("h", 60.0); targetDew = prefs.getDouble("d", 54.0);
  useDewPointMode = prefs.getBool("mode", false); useCelsius = prefs.getBool("useCelsius", false);
  writeIdx = prefs.getInt("idx", 0); is24HourMode = prefs.getBool("is24h", false);
  prefs.getBytes("history", (uint8_t*)history, sizeof(history));
  prefs.end();

  pidTemp.SetMode(AUTOMATIC); pidHum.SetMode(AUTOMATIC);
  WiFi.begin(ssid, password); while (WiFi.status() != WL_CONNECTED) delay(500); 

  configTime(-18000, 3600, ntpServer); 
  struct tm ti; 
  if(getLocalTime(&ti)){ 
    // FIX 2: Correct 32-byte buffer for full boot date/time [Source: Conversation History]
    char b[20]; 
    strftime(b, sizeof(b), "%Y-%m-%d %H:%M:%S", &ti); 
    bootTimestamp = String(b); 
  }

  ArduinoOTA.begin(); server.on("/", handleRoot); server.on("/data", handleData); server.on("/set", handleSet); server.on("/mode", handleMode); server.on("/unit", handleUnit); server.on("/kill", handleKill); server.begin(); 
}

void loop() {
  ArduinoOTA.handle(); server.handleClient(); 
  curT=(sht31.readTemperature() * 1.8) + 32; curH=sht31.readHumidity();
  float t_c=(curT-32)/1.8; double a=((17.27* t_c)/(237.7+t_c))+log(curH/100.0); curDew=((237.7*a)/(17.27-a)*1.8)+32; 
  
  if (millis() - lastSample > currentInterval) { 
    struct tm ti;
    // FIX 3: Buffer of 6 for "HH:MM\0" [Conversation History]
    char timeBuf[6] = "--:--"; 
    if(getLocalTime(&ti)) strftime(timeBuf, sizeof(timeBuf), "%H:%M", &ti); 
    
    history[writeIdx].t = (float)curT;
    history[writeIdx].h = (float)curH;
    history[writeIdx].d = (float)curDew;
    // Safely copy the timestamp into the DataPoint's fixed-size array
    strncpy(history[writeIdx].time, timeBuf, 6); 
    
    writeIdx = (writeIdx + 1) % MAX_POINTS; 
    lastSample = millis(); 
    prefs.begin("curing", false); 
    prefs.putInt("idx", writeIdx); 
    prefs.putBytes("history", (uint8_t*)history, sizeof(history)); 
    prefs.end();
    
    if (writeIdx == 0 && !is24HourMode) { 
        is24HourMode = true; 
        currentInterval = 900000; 
        prefs.begin("curing", false); 
        prefs.putBool("is24h", true); 
        prefs.end(); 
    }
  }
  
  if (!isKilled) { 
    pidHumInput = useDewPointMode ? curDew : curH; pidHumTarget = useDewPointMode ? targetDew : targetH; 
    pidTemp.Compute(); pidHum.Compute(); 
    isAssistMode = false; if (pwrT >= 250 && curT > (targetT + 5.0)) { pwrB = 255; isAssistMode = true; } 
  }
  
  fT_out = (pwrT > 0) ? 255 : 0; fT_in = (pwrT > 100) ? 255 : 0; 
  fB_out = (pwrB > 0) ? 255 : 0; fB_in = (pwrB > 100) ? 255 : 0;
  
  // Safety Cutoff (158F / 70C) [Source: Specification 28]
  if (getF(THERM_T_HOT)>158.0 || getF(THERM_B_HOT)>158.0) { pwrT=0; pwrB=0; fT_out=255; fB_out=255; } 
  
  ledcWrite(PELTIER_T, (int)pwrT); ledcWrite(PELTIER_B, (int)pwrB); 
  ledcWrite(FAN_T_IN, fT_in); ledcWrite(FAN_T_OUT, fT_out); 
  ledcWrite(FAN_B_IN, fB_in); ledcWrite(FAN_B_OUT, fB_out); 
}
